FROM archlinux:latest

RUN pacman -Syu --noconfirm && \
    pacman -S --noconfirm \
    base-devel \
    ca-certificates \
    curl \
    flatpak \
    git \
    jq \
    libxcrypt-compat \
    python3 \
    sudo

RUN useradd -m -s /bin/bash linuxbrew && \
    echo "linuxbrew ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers && \
    su - linuxbrew -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" </dev/null

RUN su - linuxbrew -c "flatpak remote-add --if-not-exists --user flathub https://flathub.org/repo/flathub.flatpakrepo"

ENV PATH="/home/linuxbrew/.linuxbrew/bin:${PATH}"

ARG BIN
COPY $BIN /usr/local/bin/stamp
COPY test/integration/arch.sh /test.sh
USER linuxbrew
CMD ["/test.sh"]
